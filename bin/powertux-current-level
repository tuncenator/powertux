#!/usr/bin/env python3
"""Print current powertux level (1-4), or 0 if no powertux profile is active.

Reads the active TCC profile via D-Bus (com.tuxedocomputers.tccd).
"""
import json
import re
import subprocess
import sys

LEVEL_BY_ID = {
    "powertux-silent": 1,
    "powertux-quiet": 2,
    "powertux-balanced": 3,
    "powertux-perf": 4,
}


def main():
    r = subprocess.run(
        [
            "busctl",
            "call",
            "com.tuxedocomputers.tccd",
            "/com/tuxedocomputers/tccd",
            "com.tuxedocomputers.tccd",
            "GetActiveProfileJSON",
        ],
        capture_output=True,
        text=True,
    )
    if r.returncode != 0:
        print(0)
        return
    m = re.search(r's "(.+)"\s*$', r.stdout.strip(), re.DOTALL)
    if not m:
        print(0)
        return
    try:
        d = json.loads(m.group(1).encode().decode("unicode_escape"))
    except (json.JSONDecodeError, UnicodeDecodeError):
        print(0)
        return
    print(LEVEL_BY_ID.get(d.get("id"), 0))


if __name__ == "__main__":
    main()
