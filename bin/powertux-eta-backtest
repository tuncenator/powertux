#!/usr/bin/env python3
"""powertux-eta-backtest: simulate proposed ETA fixes against history.

Tests candidate algorithms against actual cycle endings in the JSONL
log, side-by-side with the current production formula:

  Discharge:
    baseline-d   = naive-15 (current deployed: 15-min w_sys rolling
                   mean over OCV-Wh - 10% floor; same as
                   compute_eta_empty_s in autod)
    coldsupp-d   = baseline-d but returns None for the first
                   SUPPRESS_SEC of a segment ("garbage band" hypothesis)
    tier-d       = remaining_wh / TIER_W[current_tier]. Uses the
                   calibrated load-W from results/*.json. No history
                   window; the prediction comes from "we know what this
                   tier draws under load".
    reg-d        = leave-one-segment-out linear regression. Predicts
                   w_sys from engineered features (tier one-hot,
                   load1m/5m/15m, displays_ext, brightness_pct,
                   hour-of-day cyclic, cap) then divides into
                   remaining_wh. Requires numpy.

  Charge:
    baseline-c   = (charge_full - charge_now) / current_now (kernel-ABI
                   formula, known broken on this board)
    rolling-c    = (full_wh - current_wh) / rolling-mean(v_bat * i_bat),
                   kernel `cap` as SoC source

Each candidate is simulated tick-by-tick against the same closed
segments. Output: per-segment med abs error per candidate + aggregate.

Cycle detection mirrors powertux-eta-compare (gap > 2 ticks closes a
segment; only segments with >= 30 ticks and a real end count).

numpy is the only non-stdlib dep, used by reg-d. Other candidates are
pure-stdlib.
"""
import argparse
import datetime
import gzip
import json
import math
import statistics
import sys
from collections import defaultdict
from pathlib import Path

try:
    import numpy as np
    HAS_NUMPY = True
except ImportError:
    HAS_NUMPY = False

LOG_DIR_DEFAULT = Path.home() / "Programs" / "powertux" / "log"
TICK_SEC = 5
GAP_SEC = 2 * TICK_SEC
MIN_SEGMENT_TICKS = 30

CELLS = 4
V_NOM_CELL = 3.7
ETA_EMPTY_FLOOR_PCT = 10
SUPPRESS_SEC = 180  # discharge cold-start band
WINDOW_SEC = 15 * 60  # rolling window for both naive-d and rolling-c
MIN_SAMPLES = 6

# Calibrated load-W per tier from results/2026-05-12-000931-odm-calibration.json
# + results/2026-05-11-232510-calibration.json (battery numbers). Used by
# tier-d as a zero-history baseline: "we know what this tier draws under
# nominal load".
TIER_W = {1: 19.0, 2: 25.0, 3: 41.0, 4: 64.0}
TIER_W_FALLBACK = 25.0  # if `current` is None (auto hasn't applied yet)

OCV_SOC = [
    (4.20, 100), (4.15, 95), (4.10, 90), (4.05, 85),
    (4.00, 80), (3.95, 75), (3.90, 70), (3.85, 60),
    (3.80, 50), (3.75, 40), (3.70, 30), (3.65, 25),
    (3.60, 20), (3.55, 15), (3.50, 10), (3.45, 5),
    (3.40, 0),
]


def ocv_soc(v_cell):
    if v_cell >= OCV_SOC[0][0]:
        return 100.0
    if v_cell <= OCV_SOC[-1][0]:
        return 0.0
    for (v_hi, s_hi), (v_lo, s_lo) in zip(OCV_SOC, OCV_SOC[1:]):
        if v_lo <= v_cell <= v_hi:
            frac = (v_cell - v_lo) / (v_hi - v_lo)
            return s_lo + (s_hi - s_lo) * frac
    return 0.0


def fmt_dur(s):
    if s is None:
        return "n/a"
    s = int(abs(s))
    if s < 60:
        return f"{s}s"
    m, s = divmod(s, 60)
    if m < 60:
        return f"{m}m{s:02d}s" if s else f"{m}m"
    h, m = divmod(m, 60)
    return f"{h}h{m:02d}m" if m else f"{h}h"


def pct(xs, p):
    if not xs:
        return float("nan")
    xs = sorted(xs)
    k = max(0, min(len(xs) - 1, int(round(p / 100.0 * (len(xs) - 1)))))
    return xs[k]


def iter_logs(log_dir, dt_from=None, dt_to=None):
    paths_by_stem = {}
    for p in Path(log_dir).iterdir():
        n = p.name
        if n.endswith(".jsonl.gz"):
            stem = n[:-9]
        elif n.endswith(".jsonl"):
            stem = n[:-6]
        else:
            continue
        prev = paths_by_stem.get(stem)
        if prev is not None and prev.name.endswith(".jsonl"):
            continue
        paths_by_stem[stem] = p
    for stem in sorted(paths_by_stem):
        try:
            d = datetime.date.fromisoformat(stem)
        except ValueError:
            continue
        if dt_from and d < dt_from.date():
            continue
        if dt_to and d > dt_to.date():
            continue
        p = paths_by_stem[stem]
        opener = gzip.open if p.name.endswith(".gz") else open
        with opener(p, "rt") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    row = json.loads(line)
                except ValueError:
                    continue
                if row.get("meta"):
                    continue
                try:
                    row["_t"] = datetime.datetime.fromisoformat(row["t"])
                except (KeyError, ValueError):
                    continue
                yield row


def find_segments(rows, status_value):
    segments = []
    cur = None
    prev_t = None
    for row in rows:
        t = row["_t"]
        status = row.get("status")
        gap = prev_t is not None and (t - prev_t).total_seconds() > GAP_SEC
        prev_t = t
        if status == status_value and not gap:
            if cur is None:
                cur = {"ticks": [], "start_t": t, "closed": False}
            cur["ticks"].append(row)
            cur["end_t"] = t
        else:
            if cur is not None:
                cur["closed"] = True
                segments.append(cur)
                cur = None
            if status == status_value:
                cur = {"ticks": [row], "start_t": t, "end_t": t,
                       "closed": False}
    return [s for s in segments
            if s["closed"] and len(s["ticks"]) >= MIN_SEGMENT_TICKS]


def full_wh(row):
    """Pack Wh from EC's learned full (raw_xif2_mah) or design fallback."""
    mah = row.get("raw_xif2_mah")
    if not mah:
        cfd = row.get("charge_full")  # uAh; design as last-resort fallback
        if cfd is None:
            return None
        mah = cfd / 1000.0
    return mah * CELLS * V_NOM_CELL / 1000.0


def remaining_wh_discharge(row):
    """OCV-derived remaining Wh to practical-empty (10% floor)."""
    v = row.get("v_bat")
    fw = full_wh(row)
    if v is None or fw is None:
        return None
    soc = ocv_soc(v / CELLS)
    usable = max(0.0, soc - ETA_EMPTY_FLOOR_PCT)
    return fw * usable / 100.0


def remaining_wh_charge(row):
    """Wh to fill: full_wh * (100 - kernel_cap) / 100."""
    cap = row.get("cap")
    fw = full_wh(row)
    if cap is None or fw is None:
        return None
    return fw * max(0.0, 100.0 - cap) / 100.0


def window_mean(history, cur_t, field, window_s, positive_only=True):
    cutoff = cur_t - datetime.timedelta(seconds=window_s)
    samples = []
    for h in reversed(history):
        if h["_t"] < cutoff:
            break
        v = h.get(field)
        if v is None:
            continue
        if positive_only and v <= 0:
            continue
        samples.append(v)
    if len(samples) < MIN_SAMPLES:
        return None
    return sum(samples) / len(samples)


def predict_baseline_d(history, cur, seg):
    rem = remaining_wh_discharge(cur)
    if rem is None or rem <= 0:
        return None
    avg_w = window_mean(history, cur["_t"], "w_sys", WINDOW_SEC,
                        positive_only=True)
    if avg_w is None or avg_w <= 0:
        return None
    return rem * 3600.0 / avg_w


def predict_coldsupp_d(history, cur, seg):
    elapsed = (cur["_t"] - seg["start_t"]).total_seconds()
    if elapsed < SUPPRESS_SEC:
        return None
    return predict_baseline_d(history, cur, seg)


def predict_tier_d(history, cur, seg):
    """remaining_wh / TIER_W[current_tier]. Zero-history baseline; the
    rolling mean is replaced by the tier's calibrated nominal load."""
    rem = remaining_wh_discharge(cur)
    if rem is None or rem <= 0:
        return None
    tier = cur.get("current")
    w = TIER_W.get(tier, TIER_W_FALLBACK)
    return rem * 3600.0 / w


# reg-d uses a per-segment regressor pre-trained via leave-one-out CV
# in main(); the predict function looks the model up by segment id.
_REG_MODELS = {}  # seg_start_t -> (w, b) numpy weights + bias


REG_FEATURE_NAMES = (
    "load1m", "load5m", "load15m",
    "L1", "L2", "L3", "L4",
    "displays_ext", "brightness_pct",
    "hour_sin", "hour_cos",
    "cap",
)


def reg_features(row):
    """Vector of REG_FEATURE_NAMES values for one tick. None if any
    required field is missing (caller skips the row)."""
    needed = ("load1m", "load5m", "load15m")
    if any(row.get(k) is None for k in needed):
        return None
    tier = row.get("current")
    cap = row.get("cap")
    if cap is None:
        return None
    de = row.get("displays_ext") or 0
    bp = row.get("brightness_pct")
    if bp is None:
        bp = 50
    t = row["_t"]
    h = t.hour + t.minute / 60.0
    return [
        row["load1m"], row["load5m"], row["load15m"],
        1.0 if tier == 1 else 0.0,
        1.0 if tier == 2 else 0.0,
        1.0 if tier == 3 else 0.0,
        1.0 if tier == 4 else 0.0,
        float(de), float(bp),
        math.sin(2 * math.pi * h / 24.0),
        math.cos(2 * math.pi * h / 24.0),
        float(cap),
    ]


def train_reg(rows):
    """OLS w_sys = X @ w + b on rows that have w_sys > 0 and full
    features. Returns (weights, bias) or None if not enough data."""
    if not HAS_NUMPY:
        return None
    X = []
    y = []
    for r in rows:
        if r.get("status") != "Discharging":
            continue
        w = r.get("w_sys")
        if w is None or w <= 0:
            continue
        fv = reg_features(r)
        if fv is None:
            continue
        X.append(fv)
        y.append(w)
    if len(X) < 20:
        return None
    X = np.asarray(X)
    y = np.asarray(y)
    # OLS with intercept via lstsq on augmented matrix.
    A = np.hstack([X, np.ones((len(X), 1))])
    coef, *_ = np.linalg.lstsq(A, y, rcond=None)
    return coef[:-1], coef[-1]


def predict_reg_d(history, cur, seg):
    """Look up pre-trained model for this segment's held-out fold;
    predict w_sys from features, divide remaining_wh by it."""
    model = _REG_MODELS.get(seg["start_t"])
    if model is None:
        return None
    rem = remaining_wh_discharge(cur)
    if rem is None or rem <= 0:
        return None
    fv = reg_features(cur)
    if fv is None:
        return None
    w_vec, b = model
    pred_w = float(np.asarray(fv) @ w_vec + b)
    if pred_w <= 0:
        return None
    return rem * 3600.0 / pred_w


def predict_baseline_c(history, cur, seg):
    """Replicate autod's compute_eta_full_s tick-by-tick from logged
    fields. Kernel ABI: (charge_full - charge_now) / current_now."""
    cf = cur.get("charge_full")
    cn = cur.get("charge_now")
    i = cur.get("i_bat")
    if cf is None or cn is None or i is None or i <= 0:
        return None
    if cf <= cn:
        return 0.0
    return (cf - cn) / 1e6 / i * 3600.0


def predict_rolling_c(history, cur, seg):
    """V*I rolling mean: average charging power over last WINDOW_SEC,
    divided into remaining Wh to full (kernel cap as SoC source)."""
    rem = remaining_wh_charge(cur)
    if rem is None or rem <= 0:
        return None
    # Compute v_bat * i_bat for each historical Charging tick; rolling mean.
    cutoff = cur["_t"] - datetime.timedelta(seconds=WINDOW_SEC)
    samples = []
    for h in reversed(history):
        if h["_t"] < cutoff:
            break
        v = h.get("v_bat")
        i = h.get("i_bat")
        if v is None or i is None or i <= 0:
            continue
        samples.append(v * i)
    if len(samples) < MIN_SAMPLES:
        return None
    avg_w = sum(samples) / len(samples)
    if avg_w <= 0:
        return None
    return rem * 3600.0 / avg_w


def replay(seg, predictors):
    """For each tick in seg, run each predictor. Returns
    {name: [(pred_s, actual_s, t, soc, tier)]}. Skips ticks where the
    predictor returns None."""
    out = defaultdict(list)
    end_t = seg["end_t"]
    history = []
    for tick in seg["ticks"]:
        actual = (end_t - tick["_t"]).total_seconds()
        if actual < 0:
            continue
        soc = tick.get("cap")
        tier = tick.get("current")
        for name, fn in predictors.items():
            p = fn(history, tick, seg)
            if p is None:
                continue
            out[name].append((p, actual, tick["_t"], soc, tier))
        history.append(tick)
    return out


def stats(preds):
    if not preds:
        return None
    abs_errs = [abs(p - a) for p, a, *_ in preds]
    errs = [p - a for p, a, *_ in preds]
    pct_errs = [abs(p - a) / a for p, a, *_ in preds if a > 60]
    return {
        "n": len(preds),
        "med_abs": pct(abs_errs, 50),
        "p90_abs": pct(abs_errs, 90),
        "max_abs": max(abs_errs),
        "mean_err": sum(errs) / len(errs),
        "med_pct": (statistics.median(pct_errs)
                    if pct_errs else float("nan")),
        "overshoot_pct": sum(1 for e in errs if e > 0) * 100.0 / len(errs),
    }


def print_per_segment(label, segs, predictors, order):
    print(f"\n{label}")
    print("-" * 78)
    if not segs:
        print(f"  (no closed segments >= {MIN_SEGMENT_TICKS} ticks)")
        return
    header = f"  {'#':<3} {'start':<20} {'dur':>9} {'ticks':>5}"
    for n in order:
        header += f"  {n:>11}"
    header += "  winner"
    print(header)
    for i, seg in enumerate(segs):
        dur = (seg["end_t"] - seg["start_t"]).total_seconds() / 60
        seg_preds = replay(seg, predictors)
        row = (f"  {i:<3} {seg['start_t'].strftime('%Y-%m-%d %H:%M:%S'):<20} "
               f"{dur:>6.1f}min {len(seg['ticks']):>5}")
        meds = {}
        for name in order:
            st = stats(seg_preds.get(name, []))
            if st:
                meds[name] = st["med_abs"]
                row += f"  {fmt_dur(st['med_abs']):>11}"
            else:
                row += f"  {'n/a':>11}"
        winner = ""
        if len(meds) >= 2:
            best = min(meds, key=lambda k: meds[k])
            winner = best
        row += f"  {winner}"
        print(row)


def print_aggregate(label, segs, predictors, order):
    print(f"\n{label}")
    print("-" * 78)
    all_preds = defaultdict(list)
    for seg in segs:
        seg_preds = replay(seg, predictors)
        for name, preds in seg_preds.items():
            all_preds[name].extend(preds)
    cols = ("algo", "n", "med abs", "p90 abs", "max abs",
            "med rel", "mean signed", "overshoot%")
    print(f"  {cols[0]:<13} {cols[1]:>6}  {cols[2]:>9}  {cols[3]:>9}  "
          f"{cols[4]:>9}  {cols[5]:>7}  {cols[6]:>11}  {cols[7]:>9}")
    for name in order:
        st = stats(all_preds.get(name, []))
        if st is None:
            print(f"  {name:<13} {'-':>6}  (no data)")
            continue
        print(f"  {name:<13} {st['n']:>6}  "
              f"{fmt_dur(st['med_abs']):>9}  "
              f"{fmt_dur(st['p90_abs']):>9}  "
              f"{fmt_dur(st['max_abs']):>9}  "
              f"{st['med_pct'] * 100:>6.1f}%  "
              f"{fmt_dur(st['mean_err']):>11}  "
              f"{st['overshoot_pct']:>8.1f}%")
    # Pairwise head-to-head against the first algo (the baseline).
    if len(order) >= 2:
        baseline = order[0]
        by_t_b = {p[2]: p for p in all_preds.get(baseline, [])}
        print(f"\n  head-to-head vs {baseline} (same-tick ticks only):")
        for cand in order[1:]:
            by_t_c = {p[2]: p for p in all_preds.get(cand, [])}
            wins_b = wins_c = ties = 0
            for t in by_t_b.keys() & by_t_c.keys():
                actual = by_t_b[t][1]
                pb = by_t_b[t][0]
                pc = by_t_c[t][0]
                db = abs(pb - actual)
                dc = abs(pc - actual)
                if db < dc:
                    wins_b += 1
                elif dc < db:
                    wins_c += 1
                else:
                    ties += 1
            total = wins_b + wins_c + ties
            if total:
                print(f"    {cand:<13} {wins_c:>5}/{total} "
                      f"({wins_c * 100 / total:>5.1f}%) wins, "
                      f"{baseline} wins {wins_b * 100 / total:>5.1f}%, "
                      f"ties {ties}")


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--log-dir", default=str(LOG_DIR_DEFAULT))
    ap.add_argument("--from", dest="dt_from")
    ap.add_argument("--to", dest="dt_to")
    ap.add_argument("--mode", choices=("discharge", "charge", "both"),
                    default="both")
    args = ap.parse_args()

    dt_from = (datetime.datetime.fromisoformat(args.dt_from)
               if args.dt_from else None)
    dt_to = (datetime.datetime.fromisoformat(args.dt_to)
             if args.dt_to else None)

    rows = list(iter_logs(Path(args.log_dir), dt_from, dt_to))
    if not rows:
        print("no log data", file=sys.stderr)
        sys.exit(1)

    print("=" * 78)
    print("powertux-eta-backtest")
    print("=" * 78)
    print(f"  span    : {rows[0]['_t']} -> {rows[-1]['_t']}")
    print(f"  ticks   : {len(rows)}")
    print(f"  SUPPRESS_SEC (discharge cold-suppress) : {SUPPRESS_SEC}")
    print(f"  WINDOW_SEC (rolling mean window)       : {WINDOW_SEC}")

    if args.mode in ("discharge", "both"):
        segs = find_segments(rows, "Discharging")
        print(f"\nDISCHARGE  (closed segments >= {MIN_SEGMENT_TICKS} "
              f"ticks: {len(segs)})")

        # Train reg-d via leave-one-segment-out CV: for each held-out
        # segment, fit on the union of every other segment's ticks.
        # Caches per-segment model in _REG_MODELS keyed by start_t.
        if HAS_NUMPY:
            print("  training reg-d (leave-one-segment-out CV)...")
            for i, held in enumerate(segs):
                train_rows = []
                for j, s in enumerate(segs):
                    if j == i:
                        continue
                    train_rows.extend(s["ticks"])
                _REG_MODELS[held["start_t"]] = train_reg(train_rows)
        else:
            print("  reg-d skipped (numpy not available)")

        preds = {"baseline-d": predict_baseline_d,
                 "coldsupp-d": predict_coldsupp_d,
                 "tier-d":     predict_tier_d}
        order = ["baseline-d", "coldsupp-d", "tier-d"]
        if HAS_NUMPY:
            preds["reg-d"] = predict_reg_d
            order.append("reg-d")
        print_per_segment("Per-segment median absolute error",
                          segs, preds, order)
        print_aggregate("Aggregate accuracy", segs, preds, order)

    if args.mode in ("charge", "both"):
        segs = find_segments(rows, "Charging")
        print(f"\nCHARGE  (closed segments >= {MIN_SEGMENT_TICKS} "
              f"ticks: {len(segs)})")
        preds = {"baseline-c": predict_baseline_c,
                 "rolling-c": predict_rolling_c}
        order = ("baseline-c", "rolling-c")
        print_per_segment("Per-segment median absolute error",
                          segs, preds, order)
        print_aggregate("Aggregate accuracy", segs, preds, order)


if __name__ == "__main__":
    main()
